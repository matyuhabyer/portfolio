<article class="pb-8 max-w-3xl">
  <div class="mb-8">
    <a href="/projects" class="inline-flex items-center gap-1 text-sm font-bold text-primary hover:underline uppercase tracking-widest">
      <span class="material-symbols-outlined text-base">arrow_back</span>
      Back to Projects
    </a>
  </div>

  <header class="mb-8">
    <h1 class="font-headline font-extrabold text-3xl md:text-4xl text-on-surface mb-3">{{project.name}}</h1>
    {{#if project.label}}
      <span class="inline-block text-[10px] font-bold uppercase tracking-widest px-2 py-1 rounded-sm bg-secondary/15 text-secondary border border-secondary/25 mb-3">{{project.label}}</span>
    {{/if}}
    {{#if project.timeline}}
      <p class="font-body text-sm text-on-surface-variant mt-2">{{project.timeline}}</p>
    {{/if}}
    {{#if project.role}}
      <p class="font-body text-sm text-tertiary-fixed mt-1">{{project.role}}</p>
    {{/if}}
  </header>

  {{#if project.heroImage}}
    <div class="rounded-xl overflow-hidden border border-outline-variant/15 mb-10 shadow-2xl">
      <img src="{{project.heroImage}}" alt="{{project.name}} mockup" class="w-full h-auto object-cover"/>
    </div>
  {{/if}}

  <section class="space-y-8 font-body text-on-surface-variant">
    {{#if project.tech}}
      <p class="text-sm leading-relaxed"><span class="text-on-surface font-semibold">Skills &amp; tools:</span> {{project.tech}}</p>
    {{/if}}
    {{#if project.longDescription}}
      <p class="text-sm leading-relaxed">{{project.longDescription}}</p>
    {{/if}}

    {{#if project.highlights}}
      <div>
        <h2 class="font-headline font-bold text-xl text-on-surface mb-4">Highlights</h2>
        <ul class="list-disc list-inside space-y-2 text-sm leading-relaxed">
          {{#each project.highlights}}
            <li>{{{this}}}</li>
          {{/each}}
        </ul>
      </div>
    {{/if}}

    {{#if project.lessonsLearned}}
      {{#if (isUXProject project)}}
        <div>
          <h2 class="font-headline font-bold text-xl text-on-surface mb-4">Key Lessons Learned</h2>
          <ul class="list-disc list-inside space-y-2 text-sm leading-relaxed">
            {{#each project.lessonsLearned}}
              <li>{{{this}}}</li>
            {{/each}}
          </ul>
        </div>
      {{/if}}
    {{/if}}

    {{#if (or project.ctaUrl project.ctaPresentationUrl project.ctaPrototypeUrl)}}
      <div class="flex flex-wrap gap-4 pt-4">
        {{#if project.ctaPresentationUrl}}
          <a href="{{project.ctaPresentationUrl}}" class="inline-flex items-center justify-center px-6 py-3 rounded-md bg-primary-container text-on-primary font-headline font-bold text-sm hover:opacity-90 transition-opacity" target="_blank" rel="noopener noreferrer">
            {{#if project.ctaPresentationLabel}}{{project.ctaPresentationLabel}}{{else}}View Presentation{{/if}}
          </a>
        {{/if}}
        {{#if project.ctaPrototypeUrl}}
          <a href="{{project.ctaPrototypeUrl}}" class="inline-flex items-center justify-center px-6 py-3 rounded-md border border-outline-variant/40 text-on-surface font-headline font-bold text-sm hover:bg-surface-container-high transition-colors" target="_blank" rel="noopener noreferrer">
            {{#if project.ctaPrototypeLabel}}{{project.ctaPrototypeLabel}}{{else}}Interactive Prototype{{/if}}
          </a>
        {{/if}}
        {{#if (and (not project.ctaPresentationUrl) (not project.ctaPrototypeUrl) project.ctaUrl)}}
          <a href="{{project.ctaUrl}}" class="inline-flex items-center justify-center px-6 py-3 rounded-md bg-primary-container text-on-primary font-headline font-bold text-sm hover:opacity-90 transition-opacity" target="_blank" rel="noopener noreferrer">
            {{#if project.ctaLabel}}{{project.ctaLabel}}{{else}}View Project{{/if}}
          </a>
        {{/if}}
      </div>
    {{/if}}
  </section>
</article>
