<div class="pb-8">
  <div class="flex items-center gap-3 mb-8">
    <img src="/assets/icons/twemoji_desktop.svg" alt="" class="w-9 h-9" width="36" height="36"/>
    <h1 class="font-headline font-bold text-3xl md:text-4xl text-on-surface">Projects</h1>
  </div>
  {{#if data.projects}}
    <div class="flex flex-col gap-6">
      {{#each data.projects}}
        <a href="/projects/{{slug}}" class="group flex flex-col sm:flex-row gap-6 rounded-xl border border-outline-variant/15 bg-surface-container-low/60 p-5 md:p-6 hover:border-primary/35 hover:bg-surface-container-high/30 transition-colors">
          <div class="w-full sm:w-56 md:w-64 shrink-0 rounded-lg overflow-hidden bg-surface-container-high aspect-video sm:aspect-[4/3]">
            <img src="{{image}}" alt="{{name}}" class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300"/>
          </div>
          <div class="flex flex-col justify-center min-w-0">
            <div class="flex flex-wrap items-center gap-2 mb-2">
              <h2 class="font-headline font-bold text-xl text-on-surface group-hover:text-primary transition-colors">{{name}}</h2>
              {{#if label}}
                <span class="text-[10px] font-bold uppercase tracking-widest px-2 py-0.5 rounded-sm bg-primary/15 text-primary border border-primary/25">{{label}}</span>
              {{/if}}
            </div>
            {{#if tech}}
              <p class="font-body text-xs text-tertiary-fixed mb-2">{{tech}}</p>
            {{/if}}
            {{#if description}}
              <p class="font-body text-sm text-on-surface-variant leading-relaxed">{{description}}</p>
            {{/if}}
          </div>
        </a>
      {{/each}}
    </div>
  {{else}}
    <p class="font-body text-sm text-on-surface-variant">Projects coming soon. Check back later!</p>
  {{/if}}
</div>
